// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "favorite_models": [],
    "play_sound_when_agent_done": "always",
    "model_parameters": [],
  },
  "restore_on_startup": "last_workspace",
  "disable_ai": true,
  "text_rendering_mode": "grayscale",
  "agent_ui_font_size": 15.0,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "buffer_line_height": "standard",
  "buffer_font_weight": 300.0,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "use_system_prompts": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "project_panel": {
    "button": true,
    "default_width": 240,
    "dock": "left",
    "entry_spacing": "comfortable",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20,
    "auto_reveal_entries": true,
    "auto_fold_dirs": false,
    "bold_folder_labels": false,
    "drag_and_drop": true,
    "scrollbar": {
      "show": null,
      "horizontal_scroll": true,
    },
    "sticky_scroll": true,
    "show_diagnostics": "all",
    "indent_guides": {
      "show": "always",
    },
    "sort_mode": "directories_first",
    "hide_root": false,
    "hide_hidden": false,
    "starts_open": true,
    "auto_open": {
      "on_create": true,
      "on_paste": true,
      "on_drop": true,
    },
  },
  "minimap": {
    "show": "always",
    "thumb": "hover",
    "thumb_border": "left_open",
    "current_line_highlight": "line",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "base_keymap": "VSCode",
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
  },
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "hide_mouse": "never",
  "theme": {
    "mode": "dark",
    "light": "One Dark",
    "dark": "Catppuccin Espresso (Blur) [Light]",
  },
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
  },
  "languages": {
    "TypeScript": {
      "show_whitespaces": "all",
      "show_edit_predictions": true,
    },
    "Python": {
      "show_whitespaces": "all",
      "show_edit_predictions": true,
      "hard_tabs": true,
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
      "language_servers": [
        "ty",
        "ruff",
        "!basedpyright",
        "!pyrefly",
        "!pyright",
        "!pylsp",
      ],
    },
    "TSX": {
      "show_whitespaces": "all",
      "show_edit_predictions": true,
    },
  },
  "context_servers": {
    "react-grab-mcp": {
      "command": "npx",
      "args": ["-y", "@react-grab/mcp", "--stdio"],
      "env": {},
    },
  },
}
